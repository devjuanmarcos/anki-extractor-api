NODE_ENV=development
APP_NAME=Anki Extractor API
APP_DESCRIPTION=API local para importar pacotes .apkg do Anki com NestJS, Prisma e PostgreSQL.
PORT=3333
API_PREFIX=api
API_VERSION=1
CORS_ORIGIN=*
# PostgreSQL local sem Docker. Crie manualmente o banco anki_extractor_local.
DATABASE_URL=postgresql://postgres:2611@localhost:5432/anki_extractor_local?schema=public
DATABASE_REQUIRED=true
ENABLE_REQUEST_LOGGING=true
JWT_ACCESS_SECRET=anki-extractor-local-access-secret
JWT_REFRESH_SECRET=anki-extractor-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SWAGGER_PATH=docs/swagger
REDOC_PATH=docs
# Senha esperada para o PostgreSQL local: 2611

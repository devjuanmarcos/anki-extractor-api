NODE_ENV=development
APP_NAME=Margoni Hot API
APP_DESCRIPTION=API local do projeto Margoni Hot com NestJS, Prisma, PostgreSQL e dashboard administrativo.
PORT=3333
API_PREFIX=api
API_VERSION=1
CORS_ORIGIN=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/margoni_hot_localhost?schema=public
DATABASE_REQUIRED=true
ENABLE_REQUEST_LOGGING=true
JWT_ACCESS_SECRET=margoni-hot-local-access-secret
JWT_REFRESH_SECRET=margoni-hot-local-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
SWAGGER_PATH=docs/swagger
REDOC_PATH=docs
// Senha para acessar meu postgres localmente, caso queira usar o postgres localmente, basta criar um banco de dados com o nome "margoni_hot_dashboard" e usar a senha abaixo para acessar o banco de dados, caso queira usar o postgres do docker, basta criar um container com a imagem
SENHA_POSTGRESS=2611 